# ============================================================
# SIBYL-WAF — Environment Configuration
# ============================================================
# Salin file ini menjadi .env sebelum menjalankan docker compose:
#   cp .env.example .env
#
# Kemudian isi GEMINI_API_KEY dengan API key Anda dari:
#   https://aistudio.google.com/apikey
# ============================================================

# [WAJIB] API Key untuk Google Gemini (digunakan oleh Sibyl-Brain)
GEMINI_API_KEY=your_gemini_api_key_here

# [OPSIONAL] Port Sibyl-Brain (default: 8080)
# PORT=8080

# [OPSIONAL] URL Sibyl-Brain untuk Sibyl-Proxy (default otomatis via Docker network)
# SIBYL_BRAIN_URL=http://sibyl-brain:8080

# [OPSIONAL] URL Target Aplikasi untuk Sibyl-Proxy (default otomatis via Docker network)
# TARGET_APP_URL=http://juice-shop:3000

# [OPSIONAL] URL Valkey untuk Sibyl-Brain (default otomatis via Docker network)
# VALKEY_URL=valkey:6379
